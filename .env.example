# --- Anthropic credentials ---------------------------------------------------
# Your Anthropic API key. Leave blank if you use a custom gateway that injects auth.
ANTHROPIC_API_KEY=

# Optional: point at an OpenAI/Anthropic-compatible gateway or local endpoint.
# BASE_URL=https://your-gateway/v1

# --- Models (swappable) ------------------------------------------------------
# Fast/cheap model for generating SQL.
SQL_MODEL=claude-haiku-4-5
# Stronger model for phrasing the natural-language answer.
ANSWER_MODEL=claude-sonnet-5

# --- Source documents --------------------------------------------------------
# Path to the Excel workbook used as the database. Required.
EXCEL_PATH=data.xlsx
# Optional: path to a Word document used as the data dictionary.
# Leave unset to run Excel-only; if set but missing, a warning is shown.
# DICT_PATH=data_dictionary.docx
